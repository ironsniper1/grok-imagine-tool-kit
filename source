            const store = db.transaction('posts', 'readonly').objectStore('posts');
            store.getAll().onsuccess = ev => resolve(ev.target.result || []);
          } catch (_) { resolve(null); }
        };
      });
    }
    async function loadTagCount() {
      try {
        const res = await fetch('https://grok.com/rest/media/folder/list', {
          method: 'POST', headers: { 'Content-Type': 'application/json' }, body: '{}', credentials: 'same-origin',
        });
        if (!res.ok) return null;
        const j = await res.json();
        const arr = j.folders || j.folderList || j.list || [];
        return Array.isArray(arr) ? arr.length : null;
      } catch (_) { return null; }
    }
    function jsonCount(key) { try { const a = JSON.parse(GM_getValue(key, '[]')); return Array.isArray(a) ? a.length : 0; } catch (_) { return 0; } }
    function promptStats() {
      try {
        const a = JSON.parse(GM_getValue('grok_saved_prompts', '[]'));
        if (!Array.isArray(a)) return { n: 0, t: 0 };
        const t = a.filter(p => /\{[a-zA-Z0-9_ -]+\}/.test(String(p))).length;
        return { n: a.length, t };
      } catch (_) { return { n: 0, t: 0 }; }
    }

    function aggregate(posts) {
      const byMonth = {}; let oldest = null, newest = null; const wc = new Map();
      for (const p of posts) {
        const t = p.createTime;
        if (t) {
          const m = String(t).slice(0, 7);
          byMonth[m] = (byMonth[m] || 0) + 1;
          if (!oldest || t < oldest) oldest = t;
          if (!newest || t > newest) newest = t;
        }
        const words = (p.prompt || '').toLowerCase().match(/[a-z][a-z'-]{2,}/g) || [];
        for (const w of words) { if (!STOP.has(w)) wc.set(w, (wc.get(w) || 0) + 1); }
      }
      const topWords = [...wc.entries()].sort((a, b) => b[1] - a[1]).slice(0, 18);
      return { byMonth, oldest, newest, topWords };
    }

    // ── UI ───────────────────────────────────────────────────────────────────
    function buildUI() {
      if (built) return; built = true;

      const style = document.createElement('style');
      style.textContent = `
        #grokdash-launch { position: relative; z-index: 2147483646; background: #4f46e5; color: #fff;
          border: none; border-radius: 999px; padding: 10px 16px; font: 600 14px/1 system-ui, sans-serif;
          cursor: pointer; box-shadow: 0 4px 14px rgba(0,0,0,.35); }
        #grokdash-launch:hover { background: #4338ca; }
        #grokdash-ov { position: fixed; inset: 0; z-index: 2147483647; display: none;
          align-items: center; justify-content: center; background: rgba(0,0,0,0.6); }
        #grokdash-ov.open { display: flex; }
        #grokdash-box { width: min(620px, 94vw); max-height: 90vh; overflow: auto;
          background: #15181c; color: #e7e9ea; border: 1px solid #2f3336; border-radius: 16px;
          padding: 20px 22px; box-shadow: 0 24px 64px rgba(0,0,0,.55); font: 14px system-ui, sans-serif; }
        #grokdash-box .gd-head { display: flex; align-items: center; gap: 10px; margin-bottom: 14px; }
        #grokdash-box .gd-head h2 { margin: 0; font-size: 19px; flex: 1; }
        .gd-iconbtn { background: #20242a; color: #e7e9ea; border: 1px solid #3a3f44; border-radius: 8px;
          width: 32px; height: 32px; cursor: pointer; font-size: 14px; }
        .gd-iconbtn:hover { background: #2a2f36; }
        .gd-cards { display: grid; grid-template-columns: repeat(auto-fit, minmax(120px, 1fr)); gap: 10px; }
        .gd-card { background: #0f1216; border: 1px solid #23282e; border-radius: 12px; padding: 12px 14px; }
        .gd-card .gd-num { font-size: 22px; font-weight: 700; line-height: 1.1; }
        .gd-card .gd-lbl { font-size: 11.5px; color: #8b98a5; margin-top: 3px; }
        .gd-card .gd-sub { font-size: 11px; color: #6e7b87; margin-top: 1px; }
        .gd-span { margin: 14px 0 6px; font-size: 12.5px; color: #9fb2c8; }
        .gd-sec-title { margin: 18px 0 8px; font-size: 13px; font-weight: 600; color: #cdd1d5; }
        .gd-chart { display: flex; align-items: flex-end; gap: 4px; height: 110px; padding-top: 6px; }
        .gd-bar-wrap { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 4px; min-width: 0; }
        .gd-bar { width: 100%; max-width: 34px; background: linear-gradient(#4f46e5, #6366f1); border-radius: 4px 4px 0 0; }
        .gd-bar-val { font-size: 10px; color: #9fb2c8; }
        .gd-bar-lbl { font-size: 9.5px; color: #6e7b87; transform: rotate(-45deg); white-space: nowrap; }
        .gd-words { display: flex; flex-wrap: wrap; gap: 6px; }
        .gd-chip { background: #20242a; border: 1px solid #2f3336; border-radius: 999px; padding: 4px 10px; font-size: 12px; color: #cdd1d5; }
        .gd-chip b { color: #a5b4fc; margin-left: 5px; }
        .gd-empty { color: #8b98a5; font-size: 13px; padding: 10px 0; }
      `;
      document.head.appendChild(style);

      const btn = document.createElement('button');
      btn.id = 'grokdash-launch'; btn.type = 'button'; btn.textContent = '📊 Dashboard';
      getToolkitDock().appendChild(btn);

      overlay = document.createElement('div');
      overlay.id = 'grokdash-ov';
      overlay.innerHTML =
        '<div id="grokdash-box" role="dialog" aria-label="Toolkit dashboard">' +
          '<div class="gd-head"><h2>📊 Toolkit Dashboard</h2>' +
            '<button class="gd-iconbtn" id="grokdash-refresh" title="Refresh">↻</button>' +
            '<button class="gd-iconbtn" id="grokdash-close" title="Close">✕</button>' +
          '</div><div id="grokdash-body"><div class="gd-empty">Loading…</div></div>' +
        '</div>';
      document.body.appendChild(overlay);

      overlay.addEventListener('click', e => { if (e.target === overlay) setOpen(false); });
      overlay.querySelector('#grokdash-close').onclick = () => setOpen(false);
      overlay.querySelector('#grokdash-refresh').onclick = render;
      btn.addEventListener('click', () => { setOpen(true); render(); });
      document.addEventListener('keydown', e => { if (e.key === 'Escape' && overlay.classList.contains('open')) setOpen(false); });
    }

    function setOpen(v) { if (overlay) overlay.classList.toggle('open', v); }

    function esc(s) { return String(s).replace(/[&<>"']/g, c => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c])); }
    function fmtDay(iso) { return iso ? String(iso).slice(0, 10) : '—'; }

    async function render() {
      const body = overlay.querySelector('#grokdash-body');
      body.innerHTML = '<div class="gd-empty">Loading…</div>';

      const [posts, tagCount] = await Promise.all([loadIndexPosts(), loadTagCount()]);
      const dlCount = jsonCount('grokdl_downloaded_ids');
      const pr = promptStats();

      if (posts === null) {
        body.innerHTML = '<div class="gd-empty">Couldn’t read the search index. Open the Search bar on the Saved page once to build it, then refresh.</div>';
        // still show the other cards below the message
      }
      const list = posts || [];
      const agg = aggregate(list);

      const cards =
        card(list.length.toLocaleString(), 'Indexed images', agg.oldest ? '' : 'open Search to build') +
        card(tagCount == null ? '—' : tagCount, 'Tags', tagCount == null ? 'sign-in needed' : '') +
        card(dlCount.toLocaleString(), 'Downloaded', 'this browser') +
        card(pr.n.toLocaleString(), 'Saved prompts', pr.t ? pr.t + ' template' + (pr.t === 1 ? '' : 's') : '');

      const span = (agg.oldest || agg.newest)
        ? '<div class="gd-span">🗓 ' + fmtDay(agg.oldest) + '  →  ' + fmtDay(agg.newest) + '</div>' : '';

      // monthly bar chart (cap to most recent 12 months for width)
      const months = Object.keys(agg.byMonth).sort();
      const recent = months.slice(-12);
      const max = recent.reduce((m, k) => Math.max(m, agg.byMonth[k]), 0) || 1;
      const chart = recent.length
        ? '<div class="gd-sec-title">Activity by month</div><div class="gd-chart">' +
            recent.map(k => {
              const v = agg.byMonth[k];
              const h = Math.max(3, Math.round(v / max * 90));
              return '<div class="gd-bar-wrap" title="' + k + ': ' + v + '">' +
                '<span class="gd-bar-val">' + v + '</span>' +
                '<div class="gd-bar" style="height:' + h + 'px"></div>' +
                '<span class="gd-bar-lbl">' + k.slice(2) + '</span></div>';
            }).join('') + '</div>'
        : '';

      const words = agg.topWords.length
        ? '<div class="gd-sec-title">Top prompt keywords</div><div class="gd-words">' +
            agg.topWords.map(([w, n]) => '<span class="gd-chip">' + esc(w) + '<b>' + n + '</b></span>').join('') + '</div>'
        : '';

      body.innerHTML =
        (posts === null ? '<div class="gd-empty" style="margin-bottom:10px">Couldn’t read the search index — counts below may be partial.</div>' : '') +
        '<div class="gd-cards">' + cards + '</div>' + span + chart + words;
    }

    function card(num, label, sub) {
      return '<div class="gd-card"><div class="gd-num">' + num + '</div>' +
        '<div class="gd-lbl">' + label + '</div>' +
        (sub ? '<div class="gd-sub">' + sub + '</div>' : '') + '</div>';
    }

    if (document.body) buildUI();
    else document.addEventListener('DOMContentLoaded', buildUI);
  })();

})();
