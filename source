      '# Lines starting with # are ignored. Matching is whole-word, case-insensitive.',
      'Cats: cat, kitten, feline',
      'Landscapes: sunset, mountain, forest, ocean, beach',
      'Portraits: portrait, headshot, face',
    ].join('\n');

    function loadAutotagRules() { return GM_getValue(AUTOTAG_KEY, AUTOTAG_EXAMPLE); }
    function saveAutotagRules(text) { try { GM_setValue(AUTOTAG_KEY, text); } catch (_) {} }

    function parseAutotagRules(text) {
      const rules = [], errors = [];
      String(text || '').split('\n').forEach((line, i) => {
        const t = line.trim();
        if (!t || t.startsWith('#')) return;
        const idx = t.indexOf(':');
        if (idx < 1) { errors.push(`Line ${i + 1}: expected "Tag: keywords"`); return; }
        const tag = t.slice(0, idx).trim();
        const kws = t.slice(idx + 1).split(',').map(s => s.trim()).filter(Boolean);
        if (!tag || !kws.length) { errors.push(`Line ${i + 1}: empty tag or keywords`); return; }
        rules.push({ tag, keywords: kws });
      });
      return { rules, errors };
    }
    function compileKeywords(keywords) {
      return keywords.map(kw => {
        const esc = kw.toLowerCase().replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
        return new RegExp('\\b' + esc + '\\b', 'i');
      });
    }
    // → [{ tag, ids:[postId,…] }] using only the local index (no API).
    function computeAutotagMatches(rules) {
      const compiled = rules.map(r => ({ tag: r.tag, res: compileKeywords(r.keywords) }));
      const perRule = compiled.map(c => ({ tag: c.tag, ids: [] }));
      for (const p of allPosts) {
        const prompt = p.prompt || '';
        compiled.forEach((c, idx) => { if (c.res.some(re => re.test(prompt))) perRule[idx].ids.push(p.id); });
      }
      return perRule;
    }

    // Find an existing folder by name (case-insensitive), else create it.
    async function ensureFolder(name) {
      const existing = folders.find(f => (f.name || '').toLowerCase() === name.toLowerCase());
      if (existing) return existing.id;
      const j = await apiFolderCreate(name);
      if (!j || !j.folder || !j.folder.id) throw new Error('create returned no folder');
      folders.push(j.folder);
      folders.sort((a, b) => (a.name || '').localeCompare(b.name || ''));
      rebuildFolderIndex();
      if (!folderMembers.has(j.folder.id)) folderMembers.set(j.folder.id, new Set());
      return j.folder.id;
    }

    let autotagAbort = false;
    async function runAutotag(perRule, onStatus) {
      autotagAbort = false;
      let added = 0, skipped = 0, failed = 0, foldersTouched = 0;
      for (const { tag, ids } of perRule) {
        if (autotagAbort) break;
        if (!ids.length) continue;
        let fid;
        try { fid = await ensureFolder(tag); foldersTouched++; }
        catch (e) { onStatus(`❌ Could not create tag "${tag}": ${e.message}`); failed += ids.length; continue; }
        if (!folderMembers.has(fid)) folderMembers.set(fid, new Set());
        const members = folderMembers.get(fid);
        let n = 0;
        for (const id of ids) {
          if (autotagAbort) break;
          n++;
          if (members.has(id)) { skipped++; continue; }
          try {
            await apiAddToFolder(id, fid);
            members.add(id);
            if (!postFolders.has(id)) postFolders.set(id, new Set());
            postFolders.get(id).add(fid);
            added++;
          } catch (e) { failed++; console.error('[Autotag] add', id, e); }
          if (added % 5 === 0 || n === ids.length) {
            onStatus(`Tagging “${tag}” — ${n}/${ids.length} (added ${added}, skipped ${skipped}${failed ? `, ${failed} failed` : ''})`);
          }
          await atSleep(AUTOTAG_DELAY_MS);
        }
      }
      return { added, skipped, failed, foldersTouched, aborted: autotagAbort };
    }

