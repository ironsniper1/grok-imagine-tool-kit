    let elGrid, elCount, elSidebar, elBulkTag, elBulkBar, elPager, elSelectBtn, elPop;

    // ─── UI build ─────────────────────────────────────────────────────────────────
    function buildUI() {
      const style = document.createElement('style'); style.textContent = css; document.head.appendChild(style);

      const launch = document.createElement('button');
      launch.id = 'gtm-launch'; launch.textContent = '🏷 Tags'; launch.onclick = togglePanel;
      getToolkitDock().appendChild(launch);   // docked instead of fixed bottom-right

      const overlay = document.createElement('div');
      overlay.id = 'gtm-overlay';
      overlay.innerHTML = `
        <div id="gtm-panel">
          <div id="gtm-head">
            <input id="gtm-search" type="text" placeholder="Search prompts…" />
            <button class="gtm-btn" id="gtm-newtag">+ New tag</button>
            <button class="gtm-btn" id="gtm-autotag" title="Auto-tag images by keywords in their prompts">🪄 Auto-tag</button>
            <button class="gtm-btn" id="gtm-managetags" title="Rename, delete, or merge tags">🗂 Manage</button>
            <button class="gtm-btn" id="gtm-selectmode">Select</button>
            <button class="gtm-btn" id="gtm-refresh" title="Reload tags from Grok">↻</button>
            <span id="gtm-count"></span>
            <button class="gtm-btn" id="gtm-close">✕</button>
          </div>
          <div id="gtm-bulkbar">
            <strong id="gtm-selcount">0 selected</strong>
            <select id="gtm-bulktag"></select>
            <button class="gtm-btn primary" id="gtm-bulkadd">Add to tag</button>
            <button class="gtm-btn" id="gtm-selectall">Select page</button>
            <button class="gtm-btn" id="gtm-clearsel">Clear</button>
          </div>
          <div id="gtm-body">
            <div id="gtm-sidebar"></div>
            <div id="gtm-content">
              <div id="gtm-grid"></div>
              <div id="gtm-pager"></div>
            </div>
          </div>
        </div>`;
      document.body.appendChild(overlay);

      elPop = document.createElement('div'); elPop.id = 'gtm-pop'; document.body.appendChild(elPop);

      overlay.addEventListener('click', e => { if (e.target === overlay) togglePanel(); });
      document.addEventListener('click', e => { if (!elPop.contains(e.target) && !e.target.classList?.contains('gtm-tagbtn')) hidePop(); });

      elGrid = overlay.querySelector('#gtm-grid');
      elCount = overlay.querySelector('#gtm-count');
      elSidebar = overlay.querySelector('#gtm-sidebar');
      elBulkTag = overlay.querySelector('#gtm-bulktag');
      elBulkBar = overlay.querySelector('#gtm-bulkbar');
      elPager = overlay.querySelector('#gtm-pager');
      elSelectBtn = overlay.querySelector('#gtm-selectmode');

      overlay.querySelector('#gtm-close').onclick = togglePanel;
      overlay.querySelector('#gtm-autotag').onclick = openAutoTagModal;
      overlay.querySelector('#gtm-managetags').onclick = openManageTagsModal;
      overlay.querySelector('#gtm-search').addEventListener('input', e => { query = e.target.value; page = 0; render(); });
      overlay.querySelector('#gtm-refresh').onclick = async (e) => {
        const b = e.currentTarget; b.classList.add('gtm-busy');
        try { await refreshFolders(); } catch (err) { alert('Could not reload tags: ' + err.message); }
        b.classList.remove('gtm-busy');
      };
      overlay.querySelector('#gtm-newtag').onclick = async () => {
        const name = prompt('New tag name:');
        if (!name || !name.trim()) return;
        try {
          const j = await apiFolderCreate(name.trim());
          if (j.folder) { folders.push(j.folder); folders.sort((a, b) => a.name.localeCompare(b.name)); rebuildFolderIndex(); folderMembers.set(j.folder.id, new Set()); }
          refreshTagSelectors(); render();
        } catch (err) { alert('Could not create tag: ' + err.message); }
      };
      elSelectBtn.onclick = () => {
        selectMode = !selectMode;
        elSelectBtn.classList.toggle('on', selectMode);
        elBulkBar.classList.toggle('show', selectMode);
        if (!selectMode) selected.clear();
        render();
      };
      overlay.querySelector('#gtm-bulkadd').onclick = async (e) => {
        const fid = elBulkTag.value;
        if (!fid || selected.size === 0) return;
        const btn = e.currentTarget; btn.classList.add('gtm-busy'); btn.textContent = 'Adding…';
        const ids = [...selected];
        let ok = 0;
        for (const id of ids) {
          try { await apiAddToFolder(id, fid); ok++;
            if (!folderMembers.has(fid)) folderMembers.set(fid, new Set());
            folderMembers.get(fid).add(id);
            if (!postFolders.has(id)) postFolders.set(id, new Set());
            postFolders.get(id).add(fid);
          } catch (err) { console.error('[Tag Manager] add', id, err); }
        }
        btn.classList.remove('gtm-busy'); btn.textContent = 'Add to tag';
        selected.clear();
        refreshTagSelectors(); render();
        console.log(`[Tag Manager] added ${ok}/${ids.length} to ${folderById.get(fid)?.name || fid}`);
      };
      overlay.querySelector('#gtm-selectall').onclick = () => { for (const p of pageSlice()) selected.add(p.id); render(); };
      overlay.querySelector('#gtm-clearsel').onclick = () => { selected.clear(); render(); };
    }

    function togglePanel() {
      panelOpen = !panelOpen;
      document.getElementById('gtm-overlay').classList.toggle('open', panelOpen);
      if (panelOpen) {
        refreshTagSelectors(); render();
        // Kick off the member sweep the first time the panel is opened (deferred
        // from page load). Guarded so it runs once and not while already running.
        if (!membersLoaded && !membersLoading) loadAllMembersInBackground();
      } else hidePop();
    }

    function refreshTagSelectors() {
      const prev = elBulkTag.value;   // remember the chosen tag across the rebuild
      const opts = folders.map(f => `<option value="${esc(f.id)}">${esc(f.name)}</option>`);
      elBulkTag.innerHTML = opts.length ? opts.join('') : '<option value="">(no tags yet)</option>';
      // Keep the previously selected tag if it still exists, so it stays put
      // after adding images until you pick a different one.
      if (prev && folders.some(f => f.id === prev)) elBulkTag.value = prev;
      renderSidebar();
    }

    function renderSidebar() {
      const untagged = membersLoaded
        ? allPosts.filter(p => !postFolders.has(p.id) || postFolders.get(p.id).size === 0).length
        : '…';
      const item = (value, label, count) => {
        const active = activeFilter === value ? ' active' : '';
        return `<div class="gtm-side-item${active}" data-filter="${esc(value)}">
                  <span class="gtm-side-name">${esc(label)}</span>
                  <span class="gtm-side-count">${count}</span>
                </div>`;
      };
      elSidebar.innerHTML =
        `<div class="gtm-side-head">VIEW</div>` +
        item('__all__', 'All images', allPosts.length) +
        item('__untagged__', 'Untagged', untagged) +
        `<div class="gtm-side-head">TAGS${folders.length ? '' : ' — none yet'}</div>` +
        folders.map(f => {
          const c = folderMembers.has(f.id) ? folderMembers.get(f.id).size : '…';
          return item(f.id, f.name, c);
        }).join('');

      elSidebar.querySelectorAll('.gtm-side-item').forEach(el => {
        el.addEventListener('click', async () => {
          const f = el.dataset.filter;
          activeFilter = f; page = 0;
          if (f !== '__all__' && f !== '__untagged__' && !folderMembers.has(f)) {
            el.querySelector('.gtm-side-count').textContent = '…';
            try { await loadFolderMembers(f); } catch (e) { console.error(e); }
          }
          renderSidebar(); render();
        });
      });
    }

    function pageSlice() {
      const list = getFiltered();
      return list.slice(page * PAGE_SIZE, page * PAGE_SIZE + PAGE_SIZE);
    }

    function render() {
      renderSidebar();
      if (!allPosts.length) { renderEmpty(); return; }
      const list = getFiltered();
