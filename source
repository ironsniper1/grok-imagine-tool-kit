// ==UserScript==
// @name         Grok Imagine Toolkit
// @namespace    https://grok.com/
// @version      2.0.0
// @description  All-in-one toolkit for Grok Imagine: prompt search of your saved images, tag (folder) manager with rename/delete/merge and auto-tagging, bulk favorites downloader with ZIP export, a saved-prompts library with templates, a stats dashboard, and selectable dock styles.
// @author       You
// @match        https://grok.com/*
// @updateURL    https://github.com/ironsniper1/grok-imagine-tool-kit/releases/latest/download/Grok-Imagine-Toolkit.user.js
// @downloadURL  https://github.com/ironsniper1/grok-imagine-tool-kit/releases/latest/download/Grok-Imagine-Toolkit.user.js
// @grant        GM_xmlhttpRequest
// @grant        GM_download
// @grant        GM_setValue
// @grant        GM_getValue
// @connect      grok.com
// @connect      assets.grok.com
// @connect      imagine-public.x.ai
// @connect      x.ai
// @run-at       document-idle
// ==/UserScript==

/*
 * This file is a MERGE of three previously separate userscripts:
 *   1. Grok Imagine Favorites Search   (top-center search bar)
 *   2. Grok Imagine Tag Manager        (bottom-right launch button + modal)
 *   3. Grok Imagine Bulk Downloader v21 (bottom-right button stack + per-card buttons)
 *
 * Each tool's internal logic is left intact and wrapped in its own IIFE — nothing
 * about how they work was rewritten. The ONLY structural changes are:
 *   • A shared "dock" (#grok-toolkit-dock, bottom-right) that the Tag Manager button
 *     and the Downloader stack are re-parented into, so they stop overlapping.
 *   • The Tag Manager is gated to /imagine pages, because the merged @match is broader
 *     (grok.com/*) than its original (grok.com/imagine*).
 * The Favorites Search bar is unchanged and stays top-center in its own corner.
 */

(function () {
  'use strict';

  // ─── Shared toolkit dock ─────────────────────────────────────────────────
  // A fixed bottom-right flex column. Launchers are appended here in build order;
  // the first item built (the downloader) stays pinned to the corner, anything
  // built after it stacks upward with a gap — so nothing overlaps.
  function getToolkitDock() {
    let dock = document.getElementById('grok-toolkit-dock');
    if (dock) return dock;

    if (!document.getElementById('grok-toolkit-dock-styles')) {
      const s = document.createElement('style');
      s.id = 'grok-toolkit-dock-styles';
      s.textContent = `
        #grok-toolkit-dock {
          position: fixed; right: 20px; bottom: 20px; z-index: 2147483640;
          display: flex; flex-direction: column-reverse; align-items: flex-end;
          gap: 14px; pointer-events: none;
        }
        #grok-toolkit-dock > * { pointer-events: auto; }
        /* column-reverse: higher order = higher on screen. Top→bottom:
           Prompts, Tags, the downloader stack, then the launcher at the corner. */
        #grok-toolkit-dock > #grokset-launch { order: 1; }
        #grok-toolkit-dock > #grokdash-launch { order: 5; }
        #grok-toolkit-dock > #grokdl-v16     { order: 2; }
        #grok-toolkit-dock > #gtm-launch     { order: 3; }
        #grok-toolkit-dock > #grokpr-launch  { order: 4; }
        #grok-toolkit-toggle {
          position: relative; order: 0; z-index: 2147483646;
          background: #111827; color: #fff; border: 1px solid rgba(255,255,255,0.18);
          border-radius: 999px; padding: 11px 18px; font: 700 14px/1 system-ui, sans-serif;
          cursor: pointer; box-shadow: 0 4px 18px rgba(0,0,0,0.45);
          display: flex; align-items: center; gap: 8px;
        }
        #grok-toolkit-toggle:hover { background: #1f2937; }
        #grok-toolkit-toggle .grok-toolkit-caret { transition: transform .15s; opacity: .7; font-size: 11px; }
        #grok-toolkit-dock.expanded #grok-toolkit-toggle .grok-toolkit-caret { transform: rotate(180deg); }
        /* Collapsed: show only the launcher (override modules' inline display). */
        #grok-toolkit-dock:not(.expanded) > *:not(#grok-toolkit-toggle) { display: none !important; }

        /* === LIGHT: one consistent button language, same layout ============== */
        #grok-toolkit-dock.style-light > #grokdash-launch,
        #grok-toolkit-dock.style-light > #grokset-launch,
        #grok-toolkit-dock.style-light > #gtm-launch,
        #grok-toolkit-dock.style-light > #grokpr-launch {
          background: #20242a !important; color: #e7e9ea !important;
          border: 1px solid #343a40 !important; border-radius: 999px !important;
          font: 600 13px/1 system-ui, sans-serif !important; padding: 10px 16px !important;
          box-shadow: none !important; transition: background .12s !important;
        }
        #grok-toolkit-dock.style-light > #grokdash-launch:hover,
        #grok-toolkit-dock.style-light > #grokset-launch:hover,
        #grok-toolkit-dock.style-light > #gtm-launch:hover,
        #grok-toolkit-dock.style-light > #grokpr-launch:hover { background: #2a2f36 !important; }
        #grok-toolkit-dock.style-light > #grokdl-v16 > button {
          border-radius: 999px !important; min-width: 0 !important; box-shadow: none !important;
          font: 600 13px/1 system-ui, sans-serif !important; padding: 10px 16px !important;
        }
        #grok-toolkit-dock.style-light > #grokdl-v16 {
          background: rgba(15,18,22,0.55) !important; border: 1px solid #2a2e33 !important;
          border-radius: 12px !important; padding: 8px !important; gap: 6px !important;
        }
        #grok-toolkit-dock.style-light #grok-toolkit-toggle { background: #2a2f36 !important; }

        /* === COMPACT: horizontal strip of uniform icon buttons ============== */
        #grok-toolkit-dock.style-compact {
          flex-direction: row-reverse !important; flex-wrap: wrap-reverse !important;
          align-items: center !important; gap: 6px !important;
        }
        #grok-toolkit-dock.style-compact > #grokdash-launch,
        #grok-toolkit-dock.style-compact > #grokset-launch,
        #grok-toolkit-dock.style-compact > #gtm-launch,
        #grok-toolkit-dock.style-compact > #grokpr-launch,
        #grok-toolkit-dock.style-compact > #grokdl-launch,
        #grok-toolkit-dock.style-compact #grok-toolkit-toggle {
          width: 44px !important; height: 44px !important; padding: 0 !important; min-width: 0 !important;
          border-radius: 50% !important; background: #20242a !important; color: #e7e9ea !important;
          border: 1px solid #343a40 !important; box-shadow: 0 2px 10px rgba(0,0,0,.3) !important;
          display: flex !important; align-items: center !important; justify-content: center !important;
          font-size: 0 !important; transition: background .12s !important;
        }
        #grok-toolkit-dock.style-compact > #grokdash-launch:hover,
        #grok-toolkit-dock.style-compact > #grokset-launch:hover,
        #grok-toolkit-dock.style-compact > #gtm-launch:hover,
        #grok-toolkit-dock.style-compact > #grokpr-launch:hover,
        #grok-toolkit-dock.style-compact > #grokdl-launch:hover,
        #grok-toolkit-dock.style-compact #grok-toolkit-toggle:hover { background: #2a2f36 !important; }
        #grok-toolkit-dock.style-compact > #grokdl-launch { order: 2 !important; }
        #grok-toolkit-dock.style-compact > #grokdash-launch::before { content: '📊'; font-size: 19px; }
        #grok-toolkit-dock.style-compact > #grokset-launch::before  { content: '⚙️'; font-size: 19px; }
        #grok-toolkit-dock.style-compact > #gtm-launch::before      { content: '🏷'; font-size: 19px; }
        #grok-toolkit-dock.style-compact > #grokpr-launch::before   { content: '📝'; font-size: 19px; }
        #grok-toolkit-dock.style-compact > #grokdl-launch::before   { content: '⬇'; font-size: 19px; }
        #grok-toolkit-dock.style-compact #grok-toolkit-toggle::before { content: '🧰'; font-size: 19px; }
        #grok-toolkit-dock.style-compact #grok-toolkit-toggle { background: #2f3640 !important; }
        /* Let the 🧰 toggle actually collapse the strip: this is more specific
           than the icon-display rule above, so it wins when not expanded. */
        #grok-toolkit-dock.style-compact:not(.expanded) > *:not(#grok-toolkit-toggle) { display: none !important; }
        /* Downloader popover (compact only; element only exists in compact) */
        #grokdl-panel { position: fixed; right: 16px; bottom: 76px; z-index: 2147483000; display: none; }
        #grokdl-panel.open { display: block; }
        #grokdl-panel > #grokdl-v16 {
          display: flex !important; flex-direction: column !important; gap: 7px !important;
          background: #15181c !important; border: 1px solid #2f3336 !important;
          border-radius: 14px !important; padding: 12px !important;
          box-shadow: 0 18px 50px rgba(0,0,0,.5) !important; width: 244px !important;
        }
      `;
      document.head.appendChild(s);
    }

    dock = document.createElement('div');
    dock.id = 'grok-toolkit-dock';
    dock.classList.add('style-' + settingsGet('dockStyle'));
    document.body.appendChild(dock);

    // Master launcher: one button that shows/hides the rest of the dock.
    const toggle = document.createElement('button');
    toggle.id = 'grok-toolkit-toggle';
    toggle.type = 'button';
    toggle.innerHTML = '🧰 Grok Toolkit <span class="grok-toolkit-caret">▾</span>';
    toggle.addEventListener('click', e => { e.stopPropagation(); dock.classList.toggle('expanded'); });
    dock.appendChild(toggle);

    // Clicking anywhere outside the dock collapses it.
    document.addEventListener('click', e => {
      if (dock.classList.contains('expanded') && !dock.contains(e.target)) {
        dock.classList.remove('expanded');
      }
    });

    // The single-post / edit view (/imagine/post/...) now has its own bottom-right
    // controls (favorite, ••• menu, action strip), so hide the whole dock there
    // to avoid covering them. Re-checked on every SPA navigation.
    onPath(p => {
      dock.style.display = /\/imagine\/post\//.test(p || location.pathname) ? 'none' : '';
    });

    return dock;
  }

  // ─── Shared SPA path watcher ─────────────────────────────────────────────
  // Grok is a single-page app; the URL changes without a reload. Modules can
  // register a callback that fires immediately and again on every path change.
  const _pathCbs = [];
  let _lastPath = location.pathname;
  function onPath(cb) {
    _pathCbs.push(cb);
    try { cb(location.pathname); } catch (e) { console.error('[Toolkit] onPath', e); }
  }
  setInterval(() => {
    if (location.pathname !== _lastPath) {
      _lastPath = location.pathname;
      _pathCbs.forEach(cb => { try { cb(_lastPath); } catch (e) { console.error('[Toolkit] onPath', e); } });
    }
  }, 500);

  // ─── Shared toast notifications ──────────────────────────────────────────
  // toast('Done', 'success' | 'error' | 'info'); auto-dismisses.
  function toast(msg, type = 'info', ms = 3200) {
    if (!document.getElementById('grok-toast-styles')) {
      const s = document.createElement('style');
      s.id = 'grok-toast-styles';
      s.textContent = `
        #grok-toast-wrap { position: fixed; left: 50%; bottom: 24px; transform: translateX(-50%);
          z-index: 2147483647; display: flex; flex-direction: column; gap: 8px; align-items: center;
          pointer-events: none; font-family: system-ui, -apple-system, sans-serif; }
        .grok-toast { pointer-events: auto; min-width: 200px; max-width: 420px;
          background: rgba(15,18,22,0.97); color: #e7e9ea; border: 1px solid #2f3336;
          border-left: 3px solid #0ea5e9; border-radius: 10px; padding: 11px 16px; font-size: 13px;
          line-height: 1.4; box-shadow: 0 8px 28px rgba(0,0,0,0.5); backdrop-filter: blur(8px);
          opacity: 0; transform: translateY(8px); transition: opacity .18s, transform .18s; word-break: break-word; }
        .grok-toast.show { opacity: 1; transform: translateY(0); }
        .grok-toast.success { border-left-color: #22c55e; }
        .grok-toast.error   { border-left-color: #ef4444; }
        .grok-toast.info    { border-left-color: #0ea5e9; }
      `;
      document.head.appendChild(s);
    }
    let wrap = document.getElementById('grok-toast-wrap');
    if (!wrap) { wrap = document.createElement('div'); wrap.id = 'grok-toast-wrap'; document.body.appendChild(wrap); }
    const el = document.createElement('div');
    el.className = 'grok-toast ' + (type || 'info');
    el.textContent = msg;
    wrap.appendChild(el);
    requestAnimationFrame(() => el.classList.add('show'));
    setTimeout(() => { el.classList.remove('show'); setTimeout(() => el.remove(), 220); }, ms);
  }

  // ─── Shared file download helper (for export features) ───────────────────
  function downloadTextFile(filename, text, mime = 'application/json') {
    try {
      const blob = new Blob([text], { type: mime });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url; a.download = filename;
      document.body.appendChild(a); a.click(); a.remove();
      setTimeout(() => URL.revokeObjectURL(url), 4000);
    } catch (e) { console.error('[Toolkit] download', e); toast('Export failed: ' + e.message, 'error'); }
  }

  // ---------------------------------------------------------------------------
  // SHARED SETTINGS STORE
  // Tunables persisted under one GM key. Modules read these at load time, so
  // changes take effect on the next page reload (the Settings panel says so).
  // ---------------------------------------------------------------------------
  const SETTINGS_KEY = 'grok_toolkit_settings';
  const SETTINGS_DEFAULTS = {
    searchPageSize:  20,   // search results shown per page
    dlChunkSize:    200,   // files downloaded per batch before a pause
    dlChunkPauseSec:  5,   // seconds to pause between batches
    dlDelayMs:      250,   // delay between individual file downloads
    apiDelayMs:     700,   // delay between paged API requests
    zipBatchSize:   100,   // files per ZIP when "Bundle as ZIP" is on (bounds memory)
    dockStyle:      'classic',  // dock appearance: classic | light | compact
    filenameTemplate: '{tag}_{id}_{model}_{prompt}',  // bulk-download filename pattern (ext auto-appended)
  };
  // Per-field clamps so a bad value can't wedge a download loop.
  const SETTINGS_BOUNDS = {
    searchPageSize:  [5, 200],
    dlChunkSize:     [10, 2000],
    dlChunkPauseSec: [0, 120],
    dlDelayMs:       [0, 10000],
    apiDelayMs:      [0, 10000],
    zipBatchSize:    [10, 1000],
  };
  // Allowed values for enumerated (select) settings.
  const SETTINGS_OPTIONS = {
    dockStyle: ['classic', 'light', 'compact'],
  };
  let _settings = null;
  function settingsLoad() {
    if (_settings) return _settings;
    let saved = {};
    try { saved = JSON.parse(GM_getValue(SETTINGS_KEY, '{}')) || {}; }
    catch (e) { console.warn('[Toolkit] settings parse failed, using defaults', e); }
    _settings = Object.assign({}, SETTINGS_DEFAULTS, saved);
    return _settings;
  }
  function settingsGet(key) {
    const v = settingsLoad()[key];
    return (v === undefined) ? SETTINGS_DEFAULTS[key] : v;
  }
  function settingsClamp(key, val) {
    const n = Number(val);
    if (!isFinite(n)) return SETTINGS_DEFAULTS[key];
    const b = SETTINGS_BOUNDS[key];
    if (!b) return n;
    return Math.min(b[1], Math.max(b[0], n));
  }
  function settingsSetAll(obj) {
    const next = Object.assign({}, SETTINGS_DEFAULTS);
    Object.keys(SETTINGS_DEFAULTS).forEach(k => {
      if (obj[k] === undefined) return;
      if (typeof SETTINGS_DEFAULTS[k] === 'number') {
        if (obj[k] !== '') next[k] = settingsClamp(k, obj[k]);
      } else {
        const s = String(obj[k]).trim();
        if (SETTINGS_OPTIONS[k]) {
          next[k] = SETTINGS_OPTIONS[k].includes(s) ? s : SETTINGS_DEFAULTS[k];
        } else {
          next[k] = s || SETTINGS_DEFAULTS[k];   // never store an empty string setting
        }
      }
    });
    _settings = next;
    try { GM_setValue(SETTINGS_KEY, JSON.stringify(next)); }
    catch (e) { console.error('[Toolkit] settings save failed', e); toast('Could not save settings', 'error'); return null; }
    return next;
  }
  function settingsReset() {
    _settings = Object.assign({}, SETTINGS_DEFAULTS);
    try { GM_setValue(SETTINGS_KEY, JSON.stringify(_settings)); } catch (e) { /* non-fatal */ }
    return _settings;
  }

  // ===========================================================================
  // MODULE 1 — FAVORITES SEARCH  (verbatim; top-center, self-managed visibility)
  // ===========================================================================
  (function () {
    'use strict';

    const PAGE_SIZE   = settingsGet('searchPageSize');
    const ENDPOINT    = 'https://grok.com/rest/media/post/list';
    const DB_NAME     = 'GrokSearchIndex';
    const DB_VERSION  = 1;
    const STORE_NAME  = 'posts';

    // The search bar + indexing only run on the favorites page — not the editor
    // (/imagine/post/…) or the base create page. Change this if Grok's path differs.
    const FAVORITES_PATH = '/imagine/saved';

    const allPosts = [];
    const knownIds = new Set();
    let currentQuery = '';
    let currentPage  = 0;
    let currentSort  = 'newest';
    let matchedPosts = [];
    let dateFrom     = '';   // yyyy-mm-dd from the date picker (inclusive)
    let dateTo       = '';   // yyyy-mm-dd from the date picker (inclusive)
    let loaded       = false;

    // A search is "active" if there's a text query OR a date-range filter.
    function activeFilters() { return currentQuery.length > 0 || !!dateFrom || !!dateTo; }

    // Parse a createTime that may be an ISO string, a Unix-seconds value, or a
    // Unix-milliseconds value (number or numeric string). Returns ms, or NaN.
    function toTimestamp(v) {
      if (v == null || v === '') return NaN;
      if (typeof v === 'number') return v < 1e12 ? v * 1000 : v;
      if (typeof v === 'string') {
        if (/^\d+$/.test(v)) { const n = parseInt(v, 10); return n < 1e12 ? n * 1000 : n; }
        const t = Date.parse(v);
        return isNaN(t) ? NaN : t;
      }
      return NaN;
    }

    let db           = null;
    let indexing     = false;
    let rendering    = false;

    const sleep = ms => new Promise(r => setTimeout(r, ms));

    // ─── IndexedDB ─────────────────────────────────────────────────────────────
    function openDB() {
      return new Promise((resolve, reject) => {
        const req = indexedDB.open(DB_NAME, DB_VERSION);
        req.onupgradeneeded = e => {
          const db = e.target.result;
          if (!db.objectStoreNames.contains(STORE_NAME)) {
            const store = db.createObjectStore(STORE_NAME, { keyPath: 'id' });
            store.createIndex('createTime', 'createTime', { unique: false });
          }
        };
        req.onsuccess = e => resolve(e.target.result);
        req.onerror   = e => reject(e.target.error);
      });
    }

    function dbGetAll() {
      return new Promise((resolve, reject) => {
        const tx    = db.transaction(STORE_NAME, 'readonly');
        const store = tx.objectStore(STORE_NAME);
        const req   = store.getAll();
        req.onsuccess = e => resolve(e.target.result);
        req.onerror   = e => reject(e.target.error);
      });
    }

    function dbPutMany(posts) {
      return new Promise((resolve, reject) => {
        const tx    = db.transaction(STORE_NAME, 'readwrite');
        const store = tx.objectStore(STORE_NAME);
        posts.forEach(p => store.put(p));
        tx.oncomplete = resolve;
        tx.onerror    = e => reject(e.target.error);
      });
    }

    function dbClear() {
      return new Promise((resolve, reject) => {
        const tx    = db.transaction(STORE_NAME, 'readwrite');
        const store = tx.objectStore(STORE_NAME);
        const req   = store.clear();
        req.onsuccess = resolve;
        req.onerror   = e => reject(e.target.error);
      });
    }

    function dbCount() {
      return new Promise((resolve, reject) => {
        const tx    = db.transaction(STORE_NAME, 'readonly');
        const store = tx.objectStore(STORE_NAME);
        const req   = store.count();
        req.onsuccess = e => resolve(e.target.result);
        req.onerror   = e => reject(e.target.error);
      });
    }

    // ─── API ───────────────────────────────────────────────────────────────────
    // Set whenever a request genuinely fails (network/HTTP/parse) so callers can
    // tell a real failure apart from a clean end-of-results. Reset per run.
    let lastApiError = null;
    function fetchPage(cursor) {
      return new Promise(resolve => {
        const body = { limit: 40, filter: { source: 'MEDIA_POST_SOURCE_LIKED', safeForWork: false } };
        if (cursor) body.cursor = String(cursor);
        GM_xmlhttpRequest({
          method: 'POST', url: ENDPOINT,
          headers: { 'Content-Type': 'application/json' },
          data: JSON.stringify(body),
          withCredentials: true,
          onload: res => {
            if (res.status !== 200) {
              lastApiError = 'HTTP ' + res.status + (res.status === 401 || res.status === 403 ? ' (not signed in?)' : '');
              console.error('[GrokSearch] API error', res.status, (res.responseText || '').slice(0, 200));
              resolve(null); return;
            }
            try { resolve(JSON.parse(res.responseText)); }
            catch (e) { lastApiError = 'unreadable response'; console.error('[GrokSearch] JSON parse error', e); resolve(null); }
          },
          onerror: () => { lastApiError = 'network error'; resolve(null); },
        });
      });
    }

    function parsePost(post) {
      if (!post.id) return null;
      const prompt = post.prompt || post.originalPrompt || '';
      return {
        id:         post.id,
        prompt,
        thumbnail:  post.thumbnailImageUrl || post.mediaUrl || '',
        mediaUrl:   post.mediaUrl || '',
        createTime: post.createTime || '',
      };
    }

    // ─── Incremental: fetch only new posts until we hit a known ID ────────────
    async function fetchNewPosts(statusEl) {
      let cursor   = null;
      let newCount = 0;
      const newPosts = [];
      lastApiError = null;

      while (true) {
        const data = await fetchPage(cursor);
        if (!data) break;
        const posts = data.posts || [];

        let hitKnown = false;
        for (const post of posts) {
          if (knownIds.has(post.id)) { hitKnown = true; break; }
          const parsed = parsePost(post);
          if (parsed) { newPosts.push(parsed); newCount++; }
        }

        if (hitKnown || !data.nextCursor || posts.length === 0) break;
        cursor = data.nextCursor;
        if (statusEl) statusEl.textContent = `checking new… +${newCount}`;
        await sleep(100);
      }

      // Surface a genuine failure (vs. a clean "nothing new") so a broken or
      // signed-out session doesn't just leave search silently stale.
      if (lastApiError && newCount === 0) {
        toast('Couldn’t update search index: ' + lastApiError, 'error');
      }

      if (newPosts.length > 0) {
        // Prepend to allPosts (newest first)
        for (const p of newPosts) {
          allPosts.unshift(p);
          knownIds.add(p.id);
        }
        await dbPutMany(newPosts);
      }

      return newCount;
    }

    // ─── Full index: serial fetch with no artificial delay ───────────────────
    async function fetchFullIndex(statusEl) {
      const allFetched = [];
      let cursor = null;
      lastApiError = null;

      while (true) {
        const data = await fetchPage(cursor);
        if (!data) break;
        const posts = data.posts || [];

        for (const post of posts) {
          if (knownIds.has(post.id)) continue;
          const parsed = parsePost(post);
          if (parsed) { allFetched.push(parsed); knownIds.add(parsed.id); }
        }

        if (statusEl) statusEl.textContent = `indexing… ${allFetched.length.toLocaleString()}`;

        cursor = data.nextCursor || null;
        if (!cursor || posts.length === 0) break;
        // No artificial delay — index as fast as the API allows
      }

      // Sort newest first and push to allPosts
      allFetched.sort((a, b) => {
        const ta = a.createTime ? new Date(a.createTime).getTime() : 0;
        const tb = b.createTime ? new Date(b.createTime).getTime() : 0;
        return tb - ta;
      });
      for (const p of allFetched) allPosts.push(p);

      if (lastApiError && allFetched.length === 0) {
        toast('Couldn’t build search index: ' + lastApiError, 'error');
      }

      // Save to IndexedDB in chunks to avoid long transactions
      const chunkSize = 500;
      for (let i = 0; i < allFetched.length; i += chunkSize) {
        await dbPutMany(allFetched.slice(i, i + chunkSize));
        if (statusEl) statusEl.textContent = `saving… ${Math.min(i + chunkSize, allFetched.length)}/${allFetched.length}`;
      }

      return allFetched.length;
    }

    // ─── Main loader ───────────────────────────────────────────────────────────
    async function loadAllPosts() {
      if (indexing || loaded) return;
      indexing = true;
      const statusEl = document.getElementById('grok-stamp-status');

      try {
        db = await openDB();
      } catch (e) {
        console.error('[GrokSearch] IndexedDB failed:', e);
        if (statusEl) statusEl.textContent = 'DB error';
        return;
      }

      const cached = await dbGetAll();

      if (cached.length > 0) {
        // Load from cache — deduplicate by id
        const seen = new Set();
        for (const p of cached) {
          if (seen.has(p.id)) continue;
          seen.add(p.id);
          knownIds.add(p.id);
          allPosts.push(p);
        }

        // Sort newest first
        allPosts.sort((a, b) => {
          const ta = a.createTime ? new Date(a.createTime).getTime() : 0;
          const tb = b.createTime ? new Date(b.createTime).getTime() : 0;
          return tb - ta;
        });

        loaded = true;
        console.log(`[GrokSearch] ${allPosts.length} posts loaded from IndexedDB`);
        if (statusEl) {
          statusEl.textContent = `${allPosts.length.toLocaleString()} cached`;
          setTimeout(() => { if (statusEl) statusEl.textContent = ''; }, 2000);
        }

        // Incremental check for new posts
        if (statusEl) statusEl.textContent = 'checking for new…';
        const newCount = await fetchNewPosts(statusEl);

        if (statusEl) {
          statusEl.textContent = newCount > 0
            ? `+${newCount} new (${allPosts.length.toLocaleString()} total)`
            : 'up to date';
          setTimeout(() => { if (statusEl) statusEl.textContent = ''; }, 3000);
        }
        console.log(`[GrokSearch] Incremental: ${newCount} new posts`);

      } else {
        // First time — full parallel index
        if (statusEl) statusEl.textContent = 'first-time indexing…';
        const count = await fetchFullIndex(statusEl);
        loaded = true;

        console.log(`[GrokSearch] Full index done: ${count} posts`);
        if (statusEl) {
          statusEl.textContent = `${count.toLocaleString()} indexed`;
          setTimeout(() => { if (statusEl) statusEl.textContent = ''; }, 4000);
        }
      }
    }

    // ─── Results grid ──────────────────────────────────────────────────────────
    function getGrokGrid() {
      // Full view uses masonry cards; Compact view uses a different class, so
      // fall back to any "media-post" card before walking up to the container.
      const card = document.querySelector('[class*="media-post-masonry-card"]')
                || document.querySelector('[class*="media-post"]');
      if (!card) return null;
      let el = card.parentElement;
      for (let i = 0; i < 6; i++) {
        if (!el) break;
        if (el.children.length > 3) return el;
        el = el.parentElement;
      }
      return card.parentElement;
    }

    function showResults() {
      const totalPages = Math.max(1, Math.ceil(matchedPosts.length / PAGE_SIZE));
      currentPage = Math.max(0, Math.min(currentPage, totalPages - 1));

      const start = currentPage * PAGE_SIZE;
      const page  = matchedPosts.slice(start, start + PAGE_SIZE);

      // Primary: render into a fixed opaque overlay (works in Full + Compact,
      // never behind Grok's chrome). Fallback: also hide Grok's own grid so
      // nothing shows through even if the overlay is ever covered.
      const nativeGrid = getGrokGrid();
      if (nativeGrid) nativeGrid.style.display = 'none';

      let container = document.getElementById('grok-results-grid');
      if (!container) {
        container = document.createElement('div');
        container.id = 'grok-results-grid';
        document.body.appendChild(container);
      }
      container.style.display = 'grid';

      // Each card is an <a> to the Grok editor for that post. Using a real anchor
      // (instead of a div + window.open) means middle-click, Ctrl/Cmd-click, and
      // right-click → "Copy link" all work natively, with no JS click handler.
      container.innerHTML = page.map(post => `
        <a class="grok-result-card"
           href="https://grok.com/imagine/post/${encodeURIComponent(post.id)}"
           target="_blank" rel="noopener"
           title="${escapeHtml(post.prompt)}">
          <img src="${escapeHtml(post.thumbnail)}" alt="${escapeHtml(post.prompt)}" loading="lazy" />
          <div class="grok-result-prompt">${escapeHtml(post.prompt)}</div>
        </a>
      `).join('');

      updatePager();
      // Sit the overlay just below the search bar (plus the pager when it's shown).
      const wrap = document.getElementById('grok-search-wrap');
      if (wrap) container.style.top = (wrap.getBoundingClientRect().bottom + 12) + 'px';
      container.scrollTop = 0;
    }

    function hideResults() {
      const container = document.getElementById('grok-results-grid');
      if (container) container.style.display = 'none';
      const nativeGrid = getGrokGrid();
      if (nativeGrid) nativeGrid.style.display = '';
      updatePager();
    }

    function applyFilter() {
      if (!activeFilters()) { hideResults(); return; }

      if (!loaded) {
        const noResults = document.getElementById('grok-no-results');
        if (noResults) {
          noResults.classList.add('visible');
          noResults.querySelector('span').textContent = '⏳';
          noResults.lastChild.textContent = 'Still indexing…';
        }
        return;
      }

      const terms = currentQuery.toLowerCase().split(/\s+/).filter(Boolean);
      // Match on a word boundary (\b) so e.g. "mage" matches "mage"/"mages" but
      // NOT the "mage" inside "image". Prefix-anchored only, so partial typing
      // like "warr" still matches "warrior". Regexes are built once per query.
      const matchers = terms.map(t =>
        new RegExp('\\b' + t.replace(/[.*+?^${}()|[\]\\]/g, '\\$&'))
      );

      const fromTs = dateFrom ? new Date(dateFrom + 'T00:00:00').getTime() : null;
      const toTs   = dateTo   ? new Date(dateTo   + 'T23:59:59.999').getTime() : null;

      matchedPosts = allPosts.filter(post => {
        const p = (post.prompt || '').toLowerCase();
        if (!matchers.every(re => re.test(p))) return false;
        if (fromTs !== null || toTs !== null) {
          const t = toTimestamp(post.createTime);
          if (isNaN(t)) return false;
          if (fromTs !== null && t < fromTs) return false;
          if (toTs   !== null && t > toTs)   return false;
        }
        return true;
      });

      matchedPosts.sort((a, b) => {
        const ta = a.createTime ? new Date(a.createTime).getTime() : 0;
        const tb = b.createTime ? new Date(b.createTime).getTime() : 0;
        return currentSort === 'oldest' ? ta - tb : tb - ta;
      });

      currentPage = 0;
      const noResults = document.getElementById('grok-no-results');

      if (matchedPosts.length === 0) {
        hideResults();
        if (noResults) {
          // Explain *why* it's empty — especially helpful when a date range
          // excludes everything (e.g. picking a year with no images).
          let msg = 'No images match your search';
          if (dateFrom || dateTo) {
            const range = (dateFrom && dateTo) ? `between ${dateFrom} and ${dateTo}`
                        : dateFrom ? `on or after ${dateFrom}`
                        : `on or before ${dateTo}`;
            msg = currentQuery ? `No "${currentQuery}" images ${range}` : `No images ${range}`;
          }
          noResults.querySelector('span').textContent = (dateFrom || dateTo) ? '📅' : '🔍';
          noResults.lastChild.textContent = msg;
          noResults.classList.add('visible');
        }
      } else {
        if (noResults) noResults.classList.remove('visible');
        showResults();
      }
      updatePager();
    }

    function updatePager() {
      const totalPages = Math.max(1, Math.ceil(matchedPosts.length / PAGE_SIZE));
      const hasResults = activeFilters();

      const countEl   = document.getElementById('grok-search-count');
      const pagerEl   = document.getElementById('grok-pager');
      const pageLabel = document.getElementById('grok-page-label');
      const firstBtn  = document.getElementById('grok-page-first');
      const prevBtn   = document.getElementById('grok-page-prev');
      const nextBtn   = document.getElementById('grok-page-next');
      const lastBtn   = document.getElementById('grok-page-last');

      if (countEl)   countEl.textContent   = hasResults ? `${matchedPosts.length.toLocaleString()} match${matchedPosts.length !== 1 ? 'es' : ''}` : '';
      if (pagerEl)   pagerEl.style.display = hasResults ? 'flex' : 'none';
      if (pageLabel) pageLabel.textContent  = `${(currentPage + 1).toLocaleString()} / ${totalPages.toLocaleString()}`;
      if (firstBtn)  firstBtn.disabled      = currentPage === 0;
      if (prevBtn)   prevBtn.disabled       = currentPage === 0;
      if (nextBtn)   nextBtn.disabled       = currentPage >= totalPages - 1;
      if (lastBtn)   lastBtn.disabled       = currentPage >= totalPages - 1;
    }

    function escapeHtml(str) {
      return String(str || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }

