          renderList(); refreshTagSelectors(); render();
          toast('Renamed to "' + name + '"', 'success');
        } catch (e) { out.innerHTML = '<span style="color:#ef4444">❌ Rename failed: ' + esc(e.message) + '</span>'; }
      }

      delBtn.onclick = async () => {
        const ids = checkedIds();
        if (!ids.length) { out.textContent = 'Select one or more tags to delete.'; return; }
        const names = ids.map(id => (folderById.get(id) || {}).name || id);
        if (!confirm('Delete ' + ids.length + ' tag' + (ids.length === 1 ? '' : 's') + '?\n\n' +
          names.join(', ') + '\n\nThis removes only the tag(s). Your images stay in your library. This cannot be undone.')) return;
        busy = true; manageAbort = false;
        delBtn.disabled = mergeBtn.disabled = true; abortBtn.style.display = '';
        abortBtn.onclick = () => { manageAbort = true; abortBtn.disabled = true; abortBtn.textContent = 'Stopping…'; };
        let done = 0, failed = 0;
        for (const id of ids) {
          if (manageAbort) break;
          try { await apiFolderDelete(id); done++; }
          catch (e) { failed++; console.error('[Tag Manager] delete', id, e); }
          out.textContent = 'Deleting… ' + done + '/' + ids.length + (failed ? ' (' + failed + ' failed)' : '');
          await atSleep(AUTOTAG_DELAY_MS);
        }
        try { await refreshFolders(); } catch (_) {}
        renderList(); refreshTagSelectors(); render();
        out.innerHTML = '<strong>' + (manageAbort ? '■ Stopped' : '✅ Done') + '.</strong> Deleted ' + done + ' tag(s)' + (failed ? ', ' + failed + ' failed' : '') + '.';
        toast('Deleted ' + done + ' tag(s)' + (failed ? ', ' + failed + ' failed' : ''), failed ? 'error' : 'success');
        busy = false; delBtn.disabled = mergeBtn.disabled = false;
        abortBtn.style.display = 'none'; abortBtn.disabled = false; abortBtn.textContent = '■ Stop';
      };

      mergeBtn.onclick = () => {
        const ids = checkedIds();
        if (ids.length < 2) { out.textContent = 'Select at least two tags to merge.'; return; }
        targetSel.innerHTML = ids.map(id => '<option value="' + esc(id) + '">' + esc((folderById.get(id) || {}).name || id) + '</option>').join('');
        mergePanel.classList.add('open');
        out.textContent = '';
      };
      mergeCancel.onclick = () => mergePanel.classList.remove('open');

      mergeGo.onclick = async () => {
        const ids = checkedIds();
        if (ids.length < 2) { mergePanel.classList.remove('open'); return; }
        const targetId = targetSel.value;
        const target = folderById.get(targetId);
        if (!target) return;
        const sources = ids.filter(id => id !== targetId);
        const delSrc = delSrcChk.checked;
        if (!confirm('Merge ' + sources.length + ' tag(s) into "' + target.name + '"?\n\n' +
          'Every image in the other tag(s) will be added to "' + target.name + '".' +
          (delSrc ? '\nThe other tag(s) will then be deleted (images are kept).' : '\nThe other tag(s) will be kept.') +
          '\n\nThis cannot be undone.')) return;

        busy = true; manageAbort = false;
        mergePanel.classList.remove('open');
        delBtn.disabled = mergeBtn.disabled = true; abortBtn.style.display = '';
        abortBtn.onclick = () => { manageAbort = true; abortBtn.disabled = true; abortBtn.textContent = 'Stopping…'; };

        let added = 0, failed = 0, deleted = 0, keptForSafety = 0;
        const tMembers = await fetchFolderMemberIds(targetId).catch(() => new Set());
        for (const sid of sources) {
          if (manageAbort) break;
          const sName = (folderById.get(sid) || {}).name || sid;
          let members;
          try { members = await fetchFolderMemberIds(sid); }
          catch (e) { failed++; out.textContent = 'Could not read "' + sName + '": ' + e.message; continue; }
          let srcOk = true, n = 0;
          for (const mid of members) {
            if (manageAbort) break;
            n++;
            if (tMembers.has(mid)) continue;           // already in target — idempotent skip
            try { await apiAddToFolder(mid, targetId); tMembers.add(mid); added++; }
            catch (e) { srcOk = false; failed++; console.error('[Tag Manager] merge add', mid, e); }
            out.textContent = 'Merging "' + sName + '" → "' + target.name + '" — ' + n + '/' + members.size +
              ' (added ' + added + (failed ? ', ' + failed + ' failed' : '') + ')';
            await atSleep(AUTOTAG_DELAY_MS);
          }
          // Only delete a source if every member moved cleanly and we weren't stopped.
          if (delSrc && srcOk && !manageAbort) {
            try { await apiFolderDelete(sid); deleted++; }
            catch (e) { failed++; console.error('[Tag Manager] merge delete', sid, e); }
          } else if (delSrc && (!srcOk || manageAbort)) {
            keptForSafety++;
          }
        }
        try { await refreshFolders(); } catch (_) {}
        renderList(); refreshTagSelectors(); render();
        out.innerHTML = '<strong>' + (manageAbort ? '■ Stopped' : '✅ Done') + '.</strong> Added ' + added +
          ' image(s) to "' + esc(target.name) + '"' +
          (deleted ? ', deleted ' + deleted + ' merged tag(s)' : '') +
          (keptForSafety ? ', kept ' + keptForSafety + ' tag(s) that had errors' : '') +
          (failed ? ', ' + failed + ' failed' : '') + '.';
        toast('Merge: +' + added + ' image(s)' + (failed ? ', ' + failed + ' failed' : ''), failed ? 'error' : 'success');
        busy = false; delBtn.disabled = mergeBtn.disabled = false;
        abortBtn.style.display = 'none'; abortBtn.disabled = false; abortBtn.textContent = '■ Stop';
      };

      renderList();
      // Fill in member counts if not loaded yet (background, safe — read-only).
      if (!membersLoaded && !membersLoading) loadAllMembersInBackground().then(() => { if (document.body.contains(ov)) renderList(); });
    }

    // Page through a folder's members, collecting post IDs.
    async function fetchFolderMemberIds(folderId) {
      const ids = new Set();
      let cursor = null, guard = 0;
      do {
        const body = { limit: 120, filter: { source: 'MEDIA_POST_SOURCE_LIKED', folderId, safeForWork: false } };
        if (cursor) body.cursor = cursor;
        const j = await api('/rest/media/post/list', body);
        const posts = j.posts || [];
        for (const p of posts) if (p && p.id) ids.add(p.id);
        cursor = j.nextCursor || null;
        if (!cursor && posts.length === 120) {            // fallback: oldest createTime as ms cursor
          const ts = posts.map(p => Date.parse(p.createTime)).filter(n => !isNaN(n));
          cursor = ts.length ? String(Math.min(...ts)) : null;
        }
      } while (cursor && ++guard < 80);
      return ids;
    }

    async function loadFolderMembers(folderId) {
      if (folderMembers.has(folderId)) return folderMembers.get(folderId);
      const ids = await fetchFolderMemberIds(folderId);
      folderMembers.set(folderId, ids);
      for (const id of ids) {
        if (!postFolders.has(id)) postFolders.set(id, new Set());
        postFolders.get(id).add(folderId);
      }
      return ids;
    }

    // Load every folder's members in the background, refreshing UI as each finishes.
    // Deferred until the panel is first opened so it doesn't churn on page load.
    async function loadAllMembersInBackground() {
      if (membersLoading) return;
      membersLoading = true;
      for (const f of folders) {
        try { await loadFolderMembers(f.id); } catch (e) { console.error('[Tag Manager] members', f.name, e); }
        if (panelOpen) { renderSidebar(); render(); }
      }
      membersLoaded = true;
      membersLoading = false;
      if (panelOpen) { renderSidebar(); render(); }
    }

    function rebuildFolderIndex() {
      folderById = new Map();
      for (const f of folders) folderById.set(f.id, f);
    }

    async function refreshFolders() {
      const j = await apiFolderList();
      folders = (j.folders || []).slice().sort((a, b) => a.name.localeCompare(b.name));
      rebuildFolderIndex();
      folderMembers = new Map();
      postFolders   = new Map();
      membersLoaded = false;
      membersLoading = false;
      if (panelOpen) renderSidebar();
      // Was: unconditional loadAllMembersInBackground() — that ran on every page
      // landing. Now only sweep if the panel is actually open (e.g. the ↻ button);
      // the first-open trigger in togglePanel() handles the initial load.
      if (panelOpen) loadAllMembersInBackground();
    }

    // ─── IndexedDB: read the favorites-search index (read-only) ──────────────────
    async function dbExists(name) {
      if (indexedDB.databases) { try { return (await indexedDB.databases()).some(d => d.name === name); } catch (e) { return true; } }
      return true;
    }
    function openExisting(name) {
      return new Promise((res, rej) => { const r = indexedDB.open(name); r.onsuccess = () => res(r.result); r.onerror = () => rej(r.error); });
    }
    async function readAllPosts() {
      if (!(await dbExists(SEARCH_DB))) return null;
      const db = await openExisting(SEARCH_DB);
      if (!db.objectStoreNames.contains(SEARCH_STORE)) { db.close(); return null; }
      const posts = await new Promise((res, rej) => {
        const tx = db.transaction(SEARCH_STORE, 'readonly');
        const r = tx.objectStore(SEARCH_STORE).getAll();
        r.onsuccess = () => res(r.result || []); r.onerror = () => rej(r.error);
      });
      db.close();
      return posts;
    }

    // ─── Filtering ──────────────────────────────────────────────────────────────
    function getFiltered() {
      let list = allPosts;
      if (activeFilter === '__untagged__') {
        list = list.filter(p => !postFolders.has(p.id) || postFolders.get(p.id).size === 0);
      } else if (activeFilter !== '__all__') {
        const set = folderMembers.get(activeFilter) || new Set();
        list = list.filter(p => set.has(p.id));
      }
      const q = query.trim().toLowerCase();
      if (q) {
        const terms = q.split(/\s+/).filter(Boolean);
        // Word-boundary match (\b) so "mage" matches "mage"/"mages" but not the
        // "mage" inside "image". Prefix-anchored so partial typing still works.
        const matchers = terms.map(t => new RegExp('\\b' + t.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')));
        list = list.filter(p => { const hay = (p.prompt || '').toLowerCase(); return matchers.every(re => re.test(hay)); });
      }
      return list;
    }

