        cursor: 'pointer', display: 'flex', alignItems: 'center', justifyContent: 'center',
        backdropFilter: 'blur(4px)', boxShadow: '0 2px 8px rgba(0,0,0,0.5)',
        opacity: '0', transition: 'opacity 0.15s',
        pointerEvents: 'auto',
      });

      // Show on card hover
      card.addEventListener('mouseenter', () => { btn.style.opacity = '1'; });
      card.addEventListener('mouseleave', () => { if (!btn.disabled) btn.style.opacity = '0'; });

      btn.addEventListener('click', (e) => {
        e.stopPropagation(); // don't open the image viewer
        e.preventDefault();
        downloadCard(postId, btn);
      });

      card.appendChild(btn);
    }

    function injectAllCardButtons() {
      document.querySelectorAll('.group\\/media-post-masonry-card').forEach(injectCardButton);
    }

    // Watch for new cards being added to the DOM (virtual scroll).
    // Grok's virtual scroll churns the DOM constantly, so instead of running a
    // whole-document querySelectorAll on EVERY mutation, coalesce bursts into at
    // most one sweep per 200ms.
    let _cardInjectTimer = null;
    function scheduleCardInject() {
      if (_cardInjectTimer) return;
      _cardInjectTimer = setTimeout(() => { _cardInjectTimer = null; injectAllCardButtons(); }, 200);
    }
    const cardObserver = new MutationObserver(scheduleCardInject);
    cardObserver.observe(document.body, { childList: true, subtree: true });

    // ── Boot ──────────────────────────────────────────────────────────────────
    if (document.body) buildUI();
    else new MutationObserver((_, o) => {
      if (document.body) { o.disconnect(); buildUI(); }
    }).observe(document.documentElement, { childList: true });

    let _path = location.pathname;
    setInterval(() => {
      if (location.pathname !== _path) { _path = location.pathname; setTimeout(buildUI, 800); }
    }, 500);

  })();

  // ===========================================================================
  // MODULE 4 — SAVED PROMPTS  (docked; gated to /imagine pages)
  // ===========================================================================
  (function () {
    'use strict';

    const STORAGE_KEY = 'grok_saved_prompts';
    const APPEND_KEY  = 'grok_saved_prompts_append';
    const VARVAL_KEY  = 'grok_prompt_var_values';   // remembers last-used values per variable name
    let prompts = [];
    let appendMode = false;   // false = replace prompt box, true = append to it
    let built   = false;
    let open    = false;
    let panel, listEl, inputEl;

    // ── Template variables ───────────────────────────────────────────────────
    // A saved prompt may contain {name} placeholders. On insert, we collect
    // values for each unique name and substitute. Names allow letters, digits,
    // spaces, _ and - — but NOT '|', so SD-style wildcards like {red|blue} are
    // left untouched.
    const VAR_RE = /\{([a-zA-Z0-9_ -]+)\}/g;
    function extractVars(text) {
      const seen = new Set(), out = [];
      let m; VAR_RE.lastIndex = 0;
      while ((m = VAR_RE.exec(text))) { const n = m[1].trim(); if (n && !seen.has(n)) { seen.add(n); out.push(n); } }
      return out;
    }
    function fillTemplate(text, values) {
      return text.replace(VAR_RE, (full, name) => {
        const v = values[name.trim()];
        return (v === undefined || v === '') ? full : v;
      });
    }
    function loadVarValues() {
      try { const o = JSON.parse(GM_getValue(VARVAL_KEY, '{}')); return (o && typeof o === 'object') ? o : {}; }
      catch (_) { return {}; }
    }
    function saveVarValues(map) { try { GM_setValue(VARVAL_KEY, JSON.stringify(map)); } catch (_) {} }

    function load() {
      try { const a = JSON.parse(GM_getValue(STORAGE_KEY, '[]')); prompts = Array.isArray(a) ? a : []; }
      catch (_) { prompts = []; }
      appendMode = GM_getValue(APPEND_KEY, false) === true;
    }
    function persist() { GM_setValue(STORAGE_KEY, JSON.stringify(prompts)); }

    function esc(s) { return String(s).replace(/[&<>"']/g, c => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c])); }

    // Locate Grok's "Type to imagine" box. Try the most specific selectors first,
    // then fall back to any contenteditable / textarea on the page.
    function findPromptBox() {
      return document.querySelector('textarea[placeholder*="imagine" i]')
          || document.querySelector('input[placeholder*="imagine" i]')
          || document.querySelector('textarea[placeholder*="Type to" i]')
          || document.querySelector('[contenteditable="true"]')
          || document.querySelector('textarea');
    }

    function getCurrentPrompt() {
      const el = findPromptBox();
      if (!el) return '';
      return (el.isContentEditable ? el.textContent : el.value || '').trim();
    }

    // Write into Grok's box in a way React notices (native setter + input event).
    // In append mode, add to whatever's already there (comma-separated).
    function insertPrompt(text) {
      const el = findPromptBox();
      if (!el) { alert("Couldn't find Grok's prompt box on this page."); return; }
      let finalText = text;
      if (appendMode) {
        const cur = (el.isContentEditable ? el.textContent : el.value || '').replace(/\s+$/, '');
        if (cur) finalText = cur + ', ' + text;
      }
      if (el.isContentEditable) {
        el.focus();
        el.textContent = finalText;
        el.dispatchEvent(new InputEvent('input', { bubbles: true }));
      } else {
        const proto = el.tagName === 'TEXTAREA' ? HTMLTextAreaElement.prototype : HTMLInputElement.prototype;
        const setter = Object.getOwnPropertyDescriptor(proto, 'value') && Object.getOwnPropertyDescriptor(proto, 'value').set;
        if (setter) setter.call(el, finalText); else el.value = finalText;
        el.dispatchEvent(new Event('input', { bubbles: true }));
        el.focus();
      }
    }

    // Entry point used by the list: plain prompts insert directly; templates
    // (those containing {variables}) open a small fill-in modal first.
    function usePrompt(text) {
      const vars = extractVars(text);
      if (vars.length === 0) { insertPrompt(text); setOpen(false); return; }
      openVarModal(text, vars);
    }

    let varOverlay = null;
