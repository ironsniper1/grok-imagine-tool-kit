    // ─────────────────────────────────────────────────────────────────────────

    const sleep = ms => new Promise(r => setTimeout(r, ms));

    const clean = (s, n) =>
      String(s || '').replace(/[\\/:*?"<>|]/g, '_').replace(/\s+/g, '-').slice(0, n);

    const fmtDate = ts => {
      const d = new Date(typeof ts === 'number' && ts < 1e12 ? ts * 1000 : ts);
      if (isNaN(d)) return 'unknown';
      const p = n => String(n).padStart(2, '0');
      return `${d.getFullYear()}-${p(d.getMonth()+1)}-${p(d.getDate())}_${p(d.getHours())}${p(d.getMinutes())}`;
    };

    // Build a download filename from the user's template (Settings → filename
    // template). Tokens: {tag} {id} {model} {prompt} {date} {index}. Missing
    // tokens collapse cleanly; the extension is always appended automatically.
    const FILENAME_TOKENS = ['tag', 'id', 'model', 'prompt', 'date', 'index'];
    function buildFilename(item, tagName, index, total, folder) {
      const tpl = settingsGet('filenameTemplate') || '{tag}_{id}_{model}_{prompt}';
      const pad = String(Math.max(1, total)).length;
      const tokens = {
        tag:    tagName ? clean(tagName, 40) : '',
        id:     String(item.id).slice(0, 8),
        model:  item.model || '',
        prompt: item.prompt || '',
        date:   item.date || '',
        index:  String(index).padStart(pad, '0'),
      };
      let base = tpl.replace(/\{(tag|id|model|prompt|date|index)\}/g, (_, k) => tokens[k] != null ? tokens[k] : '');
      base = base.replace(/[\\/:*?"<>|]/g, '_')   // strip filesystem-illegal chars
                 .replace(/_{2,}/g, '_')           // collapse runs left by empty tokens
                 .replace(/^[ _-]+|[ _-]+$/g, ''); // trim stray separators
      if (!base) base = tokens.id || 'grok';       // never empty
      const dir = (folder && clean(folder, 60)) || 'grok-favorites';
      return `${dir}/${base}.${item.ext}`;
    }

