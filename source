        if (currentQuery && document.activeElement !== input) {
          if (e.key === 'ArrowRight') { e.preventDefault(); currentPage++; showResults(); }
          if (e.key === 'ArrowLeft')  { e.preventDefault(); currentPage--; showResults(); }
        }
      });
    }

    // ─── Init ──────────────────────────────────────────────────────────────────
    let built = false;

    function isFavoritesPage() {
      return location.pathname.includes(FAVORITES_PATH);
    }

    // Show the UI only on the favorites page; hide it everywhere else (e.g. the
    // editor we open on card click). Runs on every SPA URL change.
    function applyVisibility() {
      const onFav = isFavoritesPage();
