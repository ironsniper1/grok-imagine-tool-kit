            const incoming = parsed
              .map(x => typeof x === 'string' ? x : (x && (x.text || x.prompt)) || '')
              .map(s => String(s).trim())
              .filter(Boolean);
            if (!incoming.length) { toast('No prompts found in that file.', 'info'); fileInput.value = ''; return; }
            const before = prompts.length;
            const seen = new Set();
            prompts = [...incoming, ...prompts].filter(p => (seen.has(p) ? false : (seen.add(p), true)));
